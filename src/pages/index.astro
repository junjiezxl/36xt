---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-parchment text-charcoal antialiased min-h-screen flex flex-col selection:bg-brand selection:text-white">
		<Header />
		<main class="flex-grow max-w-4xl mx-auto w-full px-4 sm:px-6 lg:px-8 py-16">
			<section class="text-center space-y-8 mb-20 animate-in fade-in slide-in-from-bottom-4 duration-1000">
				<h1 class="text-5xl md:text-7xl font-extrabold tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-charcoal to-charcoal/60">
					36学堂
				</h1>
				<p class="text-xl md:text-2xl text-charcoal/80 max-w-2xl mx-auto font-light leading-relaxed">
					深入浅出，通晓技术之美。<br/>记录代码世界里的三十六计。
				</p>
				<div class="pt-4 flex justify-center gap-4">
					<a href="/blog" class="inline-flex items-center justify-center px-6 py-3 border border-transparent text-base font-medium rounded-full text-white bg-brand shadow-md hover:bg-brand/90 transition-all hover:scale-105">
						阅读文章
					</a>
					<a href="/about" class="inline-flex items-center justify-center px-6 py-3 border border-charcoal/20 text-base font-medium rounded-full text-charcoal bg-white/50 backdrop-blur shadow-sm hover:bg-white/80 transition-all hover:scale-105">
						关于我
					</a>
				</div>
			</section>

			<section class="grid grid-cols-1 md:grid-cols-2 gap-8 animate-in fade-in slide-in-from-bottom-8 duration-1000 delay-150 fill-mode-both">
				<div class="bg-white/40 backdrop-blur-md rounded-2xl p-8 border border-white/60 shadow-insetSoft hover:shadow-lg transition-all duration-300 group">
					<div class="w-12 h-12 bg-brand/10 text-brand rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
						</svg>
					</div>
					<h3 class="text-xl font-semibold mb-3">极简阅读体验</h3>
					<p class="text-charcoal/70 leading-relaxed">
						回归内容本身，去除冗余的装饰。基于 Markdown 的优雅排版，让每一次阅读都成为享受。
					</p>
				</div>
				<div class="bg-white/40 backdrop-blur-md rounded-2xl p-8 border border-white/60 shadow-insetSoft hover:shadow-lg transition-all duration-300 group">
					<div class="w-12 h-12 bg-brand/10 text-brand rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
						</svg>
					</div>
					<h3 class="text-xl font-semibold mb-3">技术之美</h3>
					<p class="text-charcoal/70 leading-relaxed">
						不仅是代码的堆砌，更是思维的艺术。深入浅出地探讨技术本质，记录每一次突破与灵感。
					</p>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
